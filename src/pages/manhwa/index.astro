---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import AnimeCard from "../../components/cards/AnimeCard.astro";

const manhwa = (await getCollection("manhwa"))
  .sort((a, b) => b.data.score - a.data.score);
---

<BaseLayout
  title="Manhwa | Senkai"
  description="Explore the best Manhwa on Senkai."
>

<section class="mx-auto max-w-7xl px-6 py-20">

  <div class="mb-12">

    <p class="font-semibold uppercase tracking-[0.3em] text-violet-400">
      Manhwa
    </p>

    <h1 class="mt-2 text-5xl font-black text-white">
      Popular Manhwa
    </h1>

    <p class="mt-4 max-w-2xl text-lg text-slate-400">
      Read guides, reviews and recommendations for the world's best manhwa.
    </p>

  </div>

  <div class="grid gap-8 sm:grid-cols-2 xl:grid-cols-3">

    {
      manhwa.map((item) => (
        <AnimeCard
          title={item.data.title}
          image={item.data.image}
          rating={item.data.score}
          genre="Manhwa"
          year={item.data.date.getFullYear()}
          href={`/manhwa/${item.id}`}
        />
      ))
    }

  </div>

</section>

</BaseLayout>