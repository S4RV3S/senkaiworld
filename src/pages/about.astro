---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
title="About Senkai"
description="About Senkai"
>

<section class="mx-auto max-w-4xl px-6 py-20">

<h1 class="mb-8 text-5xl font-black text-white">
About Senkai
</h1>

<div class="prose prose-invert max-w-none">

<p>
Senkai is an independent platform dedicated to anime, manhwa, reviews,
rankings and the latest anime news.
</p>

<p>
Our goal is to provide high-quality, accurate and easy-to-read content
for anime fans around the world.
</p>

</div>

</section>

</BaseLayout>