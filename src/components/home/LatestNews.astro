---
const news = [
  {
    title: "Solo Leveling Season 2 officially announced",
    date: "July 2026",
  },
  {
    title: "Blue Lock movie receives global release",
    date: "July 2026",
  },
  {
    title: "Top 10 Manga to Read This Month",
    date: "July 2026",
  },
];
---

<section class="news-section container">

    <h2>Latest News</h2>

    <div class="news-list">

        {
            news.map(item => (
                <article class="news-card">

                    <small>{item.date}</small>

                    <h3>{item.title}</h3>

                </article>
            ))
        }

    </div>

</section>

<style>
.news-section{
    padding:80px 20px;
}

.news-section h2{
    margin-bottom:30px;
}

.news-list{
    display:grid;
    gap:20px;
}

.news-card{
    background:#18181b;
    border:1px solid #27272a;
    border-radius:14px;
    padding:24px;
    transition:.25s;
}

.news-card:hover{
    border-color:#7c3aed;
    transform:translateY(-4px);
}

.news-card small{
    color:#a78bfa;
}

.news-card h3{
    font-size:1.75rem;
    line-height:1.3;
    color:white;
    margin:14px 0;
}
</style>