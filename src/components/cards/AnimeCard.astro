---
interface Props {
  title: string;
  image: string;
  rating: number;
  genre: string;
  year: number;
  href?: string;
}

const {
  title,
  image,
  rating,
  genre,
  year,
  href = "#",
} = Astro.props;
---

<a
  href={href}
  class="group block overflow-hidden rounded-3xl border border-slate-800 bg-slate-900 transition duration-300 hover:-translate-y-2 hover:border-violet-500 hover:shadow-2xl"
>

  <img
    src={image}
    alt={title}
    class="aspect-[3/4] w-full object-cover transition duration-500 group-hover:scale-105"
  />

  <div class="space-y-4 p-6">

    <div class="flex items-center justify-between">

      <span class="rounded-full bg-violet-600 px-3 py-1 text-xs font-semibold text-white">
        {genre}
      </span>

      <span class="font-bold text-yellow-400">
        ⭐ {rating}
      </span>

    </div>

    <h2 class="text-2xl font-bold text-white">
      {title}
    </h2>

    <p class="text-slate-400">
      {year}
    </p>

  </div>

</a>