---
interface Props {
  title: string;
  excerpt: string;
  image: string;
  slug: string;
  date: Date;
}

const { title, excerpt, image, slug, date } = Astro.props;
---

<article class="overflow-hidden rounded-3xl border border-slate-800 bg-slate-900 transition duration-300 hover:-translate-y-2 hover:border-violet-500">

  <img
  src={image}
  alt={title}
  class="aspect-video w-full object-cover"
  loading="lazy"
  onerror="this.src='/images/placeholder.jpg'"
/>

  <div class="space-y-4 p-6">

    <p class="text-sm text-slate-400">
      {date.toLocaleDateString()}
    </p>

    <h3 class="text-2xl font-bold text-white">
      {title}
    </h3>

    <p class="text-slate-400">
      {excerpt}
    </p>

    <a
      href={`/news/${slug}`}
      class="font-semibold text-violet-400 transition hover:text-violet-300"
    >
      Read Full Article →
    </a>

  </div>

</article>