---
const links = [
  { name: "Home", href: "/" },
  { name: "Anime", href: "/anime" },
  { name: "Manhwa", href: "/manhwa" },
  { name: "News", href: "/news" },
  { name: "Reviews", href: "/reviews" },
  { name: "Rankings", href: "/rankings" },
];
---

<header class="sticky top-0 z-50 border-b border-slate-800 bg-slate-950/95 backdrop-blur-xl">

  <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6 lg:px-8">

    <!-- Logo -->
    <a
      href="/"
      class="text-3xl font-black tracking-wide transition hover:opacity-90"
    >
      <span class="text-violet-500">SEN</span><span class="text-white">KAI</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden items-center gap-8 md:flex">

      {
        links.map((link) => (
          <a
            href={link.href}
            class="text-base font-semibold text-white transition duration-200 hover:text-violet-400"
          >
            {link.name}
          </a>
        ))
      }

    </nav>

    <!-- Mobile Menu Button -->
    <button
      id="menu-btn"
      class="text-3xl text-white md:hidden"
      aria-label="Toggle Menu"
    >
      ☰
    </button>

  </div>

  <!-- Mobile Navigation -->
  <nav
    id="mobile-menu"
    class="hidden flex-col border-t border-slate-800 bg-slate-950 md:hidden"
  >
    {
      links.map((link) => (
        <a
          href={link.href}
          class="border-b border-slate-800 px-6 py-4 text-white transition hover:bg-slate-900 hover:text-violet-400"
        >
          {link.name}
        </a>
      ))
    }
  </nav>

</header>

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {
  const button = document.getElementById("menu-btn");
  const menu = document.getElementById("mobile-menu");

  if (!button || !menu) return;

  button.addEventListener("click", () => {
    menu.classList.toggle("hidden");
    menu.classList.toggle("flex");
  });
});
</script>