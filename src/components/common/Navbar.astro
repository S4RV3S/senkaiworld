---
const links = [
  { name: "Home", href: "/" },
  { name: "Anime", href: "/anime" },
  { name: "Manga", href: "/manga" },
  { name: "News", href: "/news" },
  { name: "Reviews", href: "/reviews" },
  { name: "Rankings", href: "/rankings" },
];
---

<header class="sticky top-0 z-50 border-b border-slate-800 bg-slate-950/90 backdrop-blur-md">

  <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6">

  <a
  href="/"
  class="text-3xl font-extrabold tracking-wide no-underline text-white"
>
  <span class="text-violet-500">SEN</span>KAI
</a>

    <button
      id="menu-btn"
      class="text-3xl text-white md:hidden"
      aria-label="Toggle Menu"
    >
      ☰
    </button>

    <nav
      id="nav-menu"
     class="absolute left-0 top-[72px] w-full flex-col gap-5 border-b border-slate-800 bg-slate-950 p-6 hidden md:static md:flex md:w-auto md:flex-row md:border-none md:bg-transparent md:p-0"
    >

      {
        links.map((link) => (
          <a
            href={link.href}
            class="font-medium text-slate-300 transition hover:text-white"
          >
            {link.name}
          </a>
        ))
      }

    </nav>

  </div>

</header>

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {
  const btn = document.getElementById("menu-btn");
  const menu = document.getElementById("nav-menu");

  if (!btn || !menu) return;

  btn.addEventListener("click", () => {
    menu.classList.toggle("show");
  });
});
</script>