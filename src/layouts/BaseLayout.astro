---
import "../styles/global.css";
import Navbar from "../components/common/Navbar.astro";
import Footer from "../components/common/Footer.astro";
import Analytics from "../components/common/Analytics.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Senkai World | Anime, Manhwa, Reviews, Rankings & Latest News",
  description = "Discover trending anime, manga, reviews, rankings and the latest anime news.",
} = Astro.props as Props;

---

<!DOCTYPE html>
<html lang="en">
  <head>
  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <meta name="google-site-verification" content="6bZTYrq3IKwT8uAnJN7GaoJGP9L6Samr4dcS0jynsOY" />

<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <title>{title}</title>

<meta name="robots" content="index, follow" />

  <meta
    name="description"
    content={description}
  />

  <meta
    name="theme-color"
    content="#020617"
  />

  <!-- SEO -->
  <link rel="canonical" href={Astro.url.href} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Senkai World" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:image" content="https://senkaiworld.in/og-image.jpg" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://senkaiworld.in/og-image.jpg" />

  <!-- PWA -->
  <link rel="manifest" href="/manifest.webmanifest" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />

  <link
    rel="preconnect"
    href="https://fonts.gstatic.com"
    crossorigin
  />

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
    rel="stylesheet"
  />

<script async src="https://www.googletagmanager.com/gtag/js?id=G-C4RE4DQKSN"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-C4RE4DQKSN');
</script>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Senkai World",
  "url": "https://senkaiworld.in",
  "description": "Anime, Manhwa, Reviews, Rankings and Latest Anime News.",
  "publisher": {
    "@type": "Organization",
    "name": "Senkai World"
  }
})} />

<Analytics />

</head>

  <body class="bg-slate-950 text-white">

    <Navbar />

    <main>
      <slot />
    </main>

    <Footer />

  </body>
</html>