---
import BaseLayout from "./BaseLayout.astro";
import MGIDWidget from "../components/ads/MGID/Widget.astro";

interface Props {
  title: string;
  description: string;

  image: string;
  category: string;

  children?: any;
}

const {
  title,
  description,
  image,
  category,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
>

<section class="mx-auto max-w-7xl px-6 py-20">

<div class="grid gap-12 lg:grid-cols-[380px_1fr]">

<img
src={image}
alt={title}
class="rounded-3xl w-full"
/>

<div>

<span class="rounded-full bg-violet-600 px-4 py-2 text-sm font-semibold">
{category}
</span>

<h1 class="mt-6 text-5xl font-black text-white">
{title}
</h1>

<MGIDWidget placement="articleTop" />

<article
id="article-content"
class="mt-10 max-w-none"
>

<slot />

</article>

</div>

</div>

</section>

<MGIDWidget placement="articleBottom" />

</BaseLayout>